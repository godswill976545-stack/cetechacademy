{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/portal",
      "destination": "/frontend/portal.html"
    },
    {
      "source": "/payment",
      "destination": "/frontend/payment.html"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api"
    }
  ],
  "experimentalServices": {
    "frontend": {
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "entrypoint": "backend",
      "routePrefix": "/_/backend"
    }
  }
}
